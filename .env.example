# Suricata eve.json path (mount from host)
EVE_LOG=/var/log/suricata/eve.json

# Pi-hole connection
PIHOLE_URL=http://pihole:80
PIHOLE_KEY_FILE=/run/secrets/pihole_api_key
PIHOLE_PASSWORD=

# Netdata (optional — falls back to psutil)
NETDATA_URL=http://netdata:19999

# Anthropic API key for the AI assistant (optional)
ANTHROPIC_API_KEY=

# Claude model override (optional)
AI_MODEL=claude-haiku-4-5-20251001

# Auth log path (mount from host for SSH event tracking)
AUTH_LOG=/var/log/host/auth.log

# Wildcard cert expiry date (YYYY-MM-DD) — used for the cert countdown card
CERT_EXPIRY=2026-01-01
